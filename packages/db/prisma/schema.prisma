generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  MEMBER
}

enum BillingPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum ListingStatus {
  LISTED
  UNLISTED
}

enum Status {
  DEPLOYED
  ERROR
  IN_PROGRESS
  PENDING
}

enum OnBoardingStatus {
  PENDING
  COMPLETED
}

enum PaymentStatus {
  CREATED
  ATTEMPTED
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  UN_VERIFIED
  VERIFIED
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  username  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  username      String
  email         String             @unique
  password      String
  description   String?
  profileBanner String             @default("")
  verification  VerificationStatus @default(UN_VERIFIED)
  onBoarding    OnBoardingStatus   @default(PENDING)
  accessToken   String?
  organizations Organization[]
  orgMembers    OrgMembers[]
  lastLoggedIn  DateTime?          @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Organization {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  orgPlan        BillingPlan  @default(BASIC)
  creatorId      String       @db.ObjectId
  creator        User         @relation(references: [id], fields: [creatorId], onDelete: Cascade)
  startedAt      DateTime?
  planExpiration DateTime?
  orgMembers     OrgMembers[]
  providers      Providers[]
  infraBoards    InfraBoard[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  purchases      Purchases[]
}

model OrgMembers {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String
  orgId        String
  role         UserType     @default(MEMBER)
  user         User         @relation(references: [id], fields: [userId], onDelete: Cascade)
  organization Organization @relation(references: [id], fields: [orgId], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Providers {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  cloudProvider String
  accesskeyId   String
  accessSecret  String
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model InfraBoard {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  boardName        String
  boardDescription String
  boardObjective   String
  orgId            String
  provider         String        @default("AWS")
  organization     Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pricing          Int           @default(0)
  currency         String        @default("INR")
  listing          ListingStatus @default(UNLISTED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchases        Purchases[]
  infraNodes       InfraNode[]
  infraLinks       InfraLink[]
  deployments      Deployment[]
}

model InfraNode {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  nodename    String
  description String
  docs        String
  config      Json
  boardId     String
  board       InfraBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sourceLinks InfraLink[] @relation("source_node")
  targetLinks InfraLink[] @relation("target_node")
  infraLinks  InfraLink[]
}

model InfraLink {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  sourceId    String     @db.ObjectId
  targetId    String     @db.ObjectId
  source      InfraNode  @relation("source_node", fields: [sourceId], references: [id], onDelete: Cascade)
  target      InfraNode  @relation("target_node", fields: [targetId], references: [id], onDelete: Cascade)
  type        String
  boardId     String
  board       InfraBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  infraNode   InfraNode? @relation(fields: [infraNodeId], references: [id])
  infraNodeId String?    @db.ObjectId
}

model Deployment {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  boardId   String
  output    String
  state     Status     @default(PENDING)
  board     InfraBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Purchases {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  buyerId           String
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  failureReason     String?
  paymentStatus     PaymentStatus
  buyer             Organization  @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  boardId           String
  board             InfraBoard    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([buyerId, boardId])
}
